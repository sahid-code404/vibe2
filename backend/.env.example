# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/culinary_compass
# Fallback to SQLite if MySQL not available
# DATABASE_URL=sqlite:///./culinary_compass.db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# External APIs
OPENTRIPMAP_API_KEY=your-opentripmap-key
GEOAPIFY_API_KEY=your-geoapify-key

# CORS
FRONTEND_URL=http://localhost:5173

# Email (for password reset — console mode by default)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@culinarycompass.com
